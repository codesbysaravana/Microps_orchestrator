## PART 4 — CI/CD Architecture (Provider Pattern Design)

To decouple your backend from Jenkins and support future integrations (GitHub Actions, GitLab CI, CircleCI), you must implement the **Provider / Adapter Design Pattern**.

### Architecture Diagram

```mermaid
classDiagram
    class PipelineOrchestrator {
        +executeBuild(project, commit) Job
    }
    class IPipelineProvider {
        <<interface>>
        +triggerBuild(config) Promise~string~
        +getStatus(externalId) Promise~BuildStatus~
        +cancelBuild(externalId) Promise~boolean~
        +getStreamLogs(externalId) Observable~string~
    }
    class JenkinsProvider {
        -jenkinsUrl string
        +triggerBuild(config) Promise~string~
    }
    class GitHubActionsProvider {
        -octokit Octokit
        +triggerBuild(config) Promise~string~
    }
    class GitLabCIProvider {
        +triggerBuild(config) Promise~string~
    }

    PipelineOrchestrator --> IPipelineProvider : Uses
    IPipelineProvider <|.. JenkinsProvider : Implements
    IPipelineProvider <|.. GitHubActionsProvider : Implements
    IPipelineProvider <|.. GitLabCIProvider : Implements
```

### TypeScript Interface Specification
```typescript
export interface BuildConfiguration {
  projectName: string;
  repoUrl: string;
  branch: string;
  commitHash?: string;
  environmentVariables: Record<string, string>;
}

export interface BuildExecutionResult {
  externalBuildId: string;
  buildUrl: string;
  status: 'QUEUED' | 'RUNNING' | 'SUCCESS' | 'FAILED';
}

export interface IPipelineProvider {
  /** Triggers a remote build pipeline and returns the external build ID */
  triggerBuild(config: BuildConfiguration): Promise<BuildExecutionResult>;
  
  /** Queries the provider for current build lifecycle status */
  getBuildStatus(externalBuildId: string): Promise<BuildExecutionResult>;
  
  /** Terminates an active build execution */
  cancelBuild(externalBuildId: string): Promise<boolean>;
}
```

